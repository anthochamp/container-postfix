cert = {{ environ('POSTFIX_SASL_TLS_CERT_FILE') }}
key = {{ environ('POSTFIX_SASL_TLS_CERT_KEY_FILE') }}
  {% endif %}

verifyChain = {% if environ('POSTFIX_SASL_TLS_SKIP_VERIFY') == '0' %}yes{% else %}no{% endif %}

{% endif %}

